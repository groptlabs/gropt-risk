
# =========================
# GROPT TRADE BOT ENV
# =========================

# Telegram
TG_BOT_TOKEN=
TG_CHAT_ID=

# Chain
CHAIN=bsc
BSC_RPC_URL=

# Watch loop
WATCH_INTERVAL_MS=15000
PER_TOKEN_DELAY_MS=150
SCAN_TIMEOUT_MS=12000

# Scores 
MIN_SCORE=5
BUY_SCORE=8
WATCH_SCORE=6

# Cooldowns 
COOLDOWN_MIN=45
SEEN_COOLDOWN_MS=60000
MAX_CANDIDATES_PER_TICK=120

# Debug
DEBUG=1
MODE=fresh
PREFILTER_ENABLED=0

# State
STATE_FILE=./state.json
STATE_SAVE_EVERY_MS=5000

# Binance Meme Rush
BN_MEME_RUSH_ENABLED=1
BN_MEME_RUSH_LIMIT=120
BN_MEME_RUSH_RANK_TYPES=30,20,10
BN_MEME_RUSH_PROTOCOLS=2001,2002
BN_MEME_RUSH_LIQ_MIN=
BN_MEME_RUSH_VOL_MIN=
BN_MEME_RUSH_MCAP_MAX=

# Binance Smart Money Signals
BN_SMART_MONEY_ENABLED=1
BN_SMART_MONEY_PAGE_SIZE=100
BN_SMART_MONEY_PAGES=2
BN_SMART_MONEY_TYPE=
BN_SMART_MONEY_ONLY_BUY=1
BN_SMART_MONEY_REQUIRE_ACTIVE=0
BN_SMART_MONEY_MIN_COUNT=0
BN_SMART_MONEY_FORCE_SEND=1
